# Database (Neon or Supabase Postgres)
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# Auth
JWT_SECRET="generate-with-openssl-rand-hex-32"

# Voice Agent API Key (shared between agent and dashboard)
AGENT_API_KEY="generate-with-openssl-rand-hex-24"

# Pusher Channels (create free app at https://pusher.com)
PUSHER_APP_ID="your_app_id"
PUSHER_SECRET="your_secret"
NEXT_PUBLIC_PUSHER_KEY="your_key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"
