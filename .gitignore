# ROS 2 workspace build artifacts
build/
install/
log/

# Nested build/install/log inside src (colcon sometimes creates these)
src/build/
src/install/
src/log/

# Colcon metadata
.colcon_install_layout
colcon_build_options.txt

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Arduino / PlatformIO (firmware)
src/fyp_bringup/firmware/.pio/
src/fyp_bringup/firmware/.vscode/
*.ino.elf
*.ino.bin
*.ino.hex

# Map files generated at runtime (keep source maps, ignore generated ones)
# Uncomment if you want to exclude all generated maps:
# src/fyp_bringup/maps/*.pgm
# src/fyp_bringup/maps/*.yaml

# Compiled shared libraries
*.so
*.so.*
*.a
*.o

# CMake artifacts
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
CTestTestfile.cmake
_deps/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# RViz session state (auto-generated, not useful to track)
*.rviz~

# SLAM Toolbox serialized maps (large binary files)
*.posegraph
*.data

# Gazebo cache
.gz/
